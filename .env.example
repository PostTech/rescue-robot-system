# ===========================================================================
# Rescue Robot System - Local Environment Configuration Template (.env.example)
# ===========================================================================
# 복사하여 .env 파일로 저장한 뒤 각 랩탑 환경에 맞게 커스텀하여 사용합니다.

# 1. Server Core Configuration (Go)
PORT=8080
ENV=development # development, staging, production
LOG_LEVEL=debug   # debug, info, warn, error

# 2. Relational Database (PostgreSQL + PostGIS)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secretpassword
DB_NAME=rescue_robot
DB_SSLMODE=disable

# 3. Object Storage (MinIO)
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_DEFAULT_BUCKET_VIDEO=video
MINIO_DEFAULT_BUCKET_AUDIO=audio
MINIO_DEFAULT_BUCKET_MAPS=maps

# 4. Robot WebRTC Bridge & Control Settings
ROBOT_GATEWAY_ADDRESS=127.0.0.1:50051
WEBRTC_SIGNALING_URL=ws://127.0.0.1:8080/webrtc/signal
LOCAL_AUTONOMOUS_FAILOVER=true

# 5. Developer Sync Directory (AI Agent Context Sync)
# 에이전트의 task.md, implementation_plan.md 아티팩트가 원격 Git으로 연동되는 폴더입니다.
DEV_SYNC_DIR=docs/dev-state
